{
    "name": "forgechat-backend",
    "version": "1.0.0",
    "description": "ForgeChat backend — real-time messaging + calls on the RTCForge stack (file-based, no database).",
    "main": "src/index.js",
    "scripts": {
        "start": "node src/index.js",
        "dev": "node --watch src/index.js",
        "test": "node test/smoke.test.js && node test/sfu.test.js && node test/cascade.test.js",
        "lint": "biome lint .",
        "format": "biome format --write .",
        "check": "biome check .",
        "check:fix": "biome check --write ."
    },
    "engines": {
        "node": ">=20"
    },
    "keywords": [
        "chat",
        "webrtc",
        "rtcforge",
        "signaling",
        "websocket"
    ],
    "author": "",
    "license": "MIT",
    "type": "commonjs",
    "dependencies": {
        "cluster-core": "^2.0.1",
        "express": "^5.2.1",
        "rtcforge-adapter-udp": "^0.1.2",
        "rtcforge-core": "^0.1.2",
        "rtcforge-media": "^0.1.2",
        "rtcforge-sdk": "^0.1.2",
        "rtcforge-sfu": "^0.1.2",
        "rtcforge-signaling": "^0.1.2",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.5.2"
    }
}
