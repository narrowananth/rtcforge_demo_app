# Copy to .env and adjust. In production TOKEN_SECRET is REQUIRED.
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# Strong random secret for signing session tokens.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
TOKEN_SECRET=dev-insecure-secret-change-me
TOKEN_TTL_MS=43200000

# Limits (SFU produce/consume handshakes burst, hence the higher default)
MAX_MESSAGES_PER_SECOND=120
MAX_MESSAGE_LENGTH=4000
MAX_STORED_MESSAGES_PER_CONVERSATION=2000
MAX_GROUP_MEMBERS=256
MAX_UPLOAD_BYTES=26214400

# Persistence
DATA_DIR=./data
FLUSH_INTERVAL_MS=800

# WebRTC ICE — delivered to the P2P data-channel transfer path (rtcforge-media
# mesh) via the signaling iceServersHook. STUN is enough on most networks; add a
# TURN server for reliable connectivity behind symmetric NAT / restrictive
# firewalls. (SFU media rooms use mediasoup's own transport candidates instead.)
STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
# TURN_URL=turn:turn.example.com:3478,turns:turn.example.com:5349
# TURN_USERNAME=youruser
# TURN_CREDENTIAL=yourpass

# SFU media (rtcforge-media → mediasoup). Real server-side selective forwarding:
# a caller/broadcaster PRODUCES once and the SFU fans out to N consumers.
SFU_ENABLED=true
# SFU_WORKERS=0                 # 0 → pool decides (≈ CPU count)
SFU_LISTEN_IP=127.0.0.1         # bind ip for mediasoup WebRTC transports
# SFU_ANNOUNCED_IP=203.0.113.10 # REQUIRED in prod: the public IP clients reach
SFU_RTC_MIN_PORT=40000
SFU_RTC_MAX_PORT=49999
SFU_CASCADE_FANOUT=4            # rtcforge-sfu CascadeTree branching for broadcasts
SFU_VIEWERS_PER_NODE=500

# Cluster (rtcforge-core Membership + HashRing). Single node by default; set
# CLUSTER_UDP_PORT to shard rooms across nodes via SWIM gossip (rtcforge-adapter-udp).
# CLUSTER_NODE_ID=node-a
# CLUSTER_REGION=us-east
# CLUSTER_UDP_PORT=7946
# CLUSTER_ADVERTISE_HOST=10.0.0.2
# CLUSTER_SEEDS=10.0.0.3:7946,10.0.0.4:7946

LOG_LEVEL=debug
